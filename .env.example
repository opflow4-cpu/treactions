# ── Upstash Redis (obrigatório em produção) ────────────────────────────────────
# Crie um banco gratuito em https://upstash.com → Redis → REST API
KV_REST_API_URL=https://your-db.upstash.io
KV_REST_API_TOKEN=your-token-here

# Alternativa: variáveis nativas do Upstash (funciona igual)
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token-here

# ── Cloudinary (upload de mídia nos blocos de fluxo) ──────────────────────────
# Crie uma conta gratuita em https://cloudinary.com
# Em Settings → Upload → Upload presets → Add preset → Signing mode: Unsigned
# Copie o Cloud name e o Preset name abaixo:
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your-upload-preset

# ── Desenvolvimento local ──────────────────────────────────────────────────────
# Sem as variáveis acima, os dados são salvos em .treactions-data.json (local only)
