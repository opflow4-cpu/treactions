# ── Upstash Redis (obrigatório em produção) ────────────────────────────────────
# Crie um banco gratuito em https://upstash.com → Redis → REST API
KV_REST_API_URL=https://your-db.upstash.io
KV_REST_API_TOKEN=your-token-here

# Alternativa: variáveis nativas do Upstash (funciona igual)
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token-here

# ── Desenvolvimento local ──────────────────────────────────────────────────────
# Sem as variáveis acima, os dados são salvos em .treactions-data.json (local only)
